<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <!-- Top Left Back Arrow -->
    <ImageButton
        android:id="@+id/btnBackToHome"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_revert"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="#FFFFFF"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Go Back" />

    <!-- Ambient Glow / Background decoration -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/glow_circle_cyan"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationX="100dp"
        android:translationY="-100dp"
        android:alpha="0.2"/>

    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:background="@drawable/glow_circle_purple"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-150dp"
        android:translationY="150dp"
        android:alpha="0.15"/>

    <!-- Main Container (No ScrollView, centered) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NYXXPAD"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:shadowColor="#88000000"
            android:shadowDx="0.0"
            android:shadowDy="4.0"
            android:shadowRadius="8.0"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WI-FI CONNECTION"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:textColor="#9E9BB1"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Glassmorphism Card -->
        <LinearLayout
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="24dp"
            android:elevation="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECTION"
                android:fontFamily="sans-serif-medium"
                android:textColor="#C5C6C7"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/ipInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/input_bg"
                android:textColor="#FFFFFF"
                android:textColorHint="#45A29E"
                android:fontFamily="monospace"
                android:hint="Manual IP (e.g. 192.168.1.5)"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"
                android:inputType="textUri" />

            <!-- Row for Connect and QR Scan to save vertical space -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnScanQr"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/btn_premium_card"
                    android:textColor="#E0E0E0"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="16sp"
                    android:text="SCAN QR" />

                <Button
                    android:id="@+id/connectButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/btn_premium_card"
                    android:textColor="#8A2BE2"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp"
                    android:text="CONNECT" />
            </LinearLayout>


        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
