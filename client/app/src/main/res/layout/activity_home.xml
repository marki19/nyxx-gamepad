<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Main Container (centered) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <!-- Branding Header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">
            
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginEnd="16dp"
                android:elevation="8dp"/>
                
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/tvNyxx"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nyxx"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    android:textColor="#FFFFFF"
                    android:textSize="40sp"
                    android:shadowColor="#88000000"
                    android:shadowDx="0.0"
                    android:shadowDy="4.0"
                    android:shadowRadius="12.0" />
                    
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ULTIMATE VIRTUAL CONTROLLER"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:textColor="#8A2BE2"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Glassmorphism Card for Modes -->
        <LinearLayout
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="32dp"
            android:elevation="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT CONNECTION"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:textColor="#C5C6C7"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnConnectWifi"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Wi-Fi / Hotspot (Local Network)"
                android:drawableStart="@drawable/ic_wifi"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:drawablePadding="16dp"
                android:gravity="center_vertical|start"
                android:background="@drawable/btn_premium_card"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnConnectUsb"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Wired (USB Tethering)"
                android:drawableStart="@drawable/ic_usb"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:drawablePadding="16dp"
                android:gravity="center_vertical|start"
                android:background="@drawable/btn_premium_card"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnConnectBluetooth"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Bluetooth"
                android:drawableStart="@drawable/ic_bluetooth"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:drawablePadding="16dp"
                android:gravity="center_vertical|start"
                android:background="@drawable/btn_premium_card"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- FAQ (?) button - top-left -->
    <LinearLayout
        android:id="@+id/faqButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvFaqIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_icon"
            android:text="?"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FAQ"
            android:textColor="#C5C6C7"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Theme Settings button - top-right -->
    <LinearLayout
        android:id="@+id/btnThemeSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THEME"
            android:textColor="#C5C6C7"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvThemeIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_icon"
            android:text="🎨"
            android:textSize="20sp"
            android:gravity="center" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvAppVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textColor="#555555"
        android:textSize="12sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Update button - bottom-right -->
    <LinearLayout
        android:id="@+id/btnUpdate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tvUpdateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHECK UPDATE"
            android:textColor="#C5C6C7"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/ivUpdateIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_circle_icon"
            android:src="@drawable/ic_update"
            android:padding="6dp"
            app:tint="#FFFFFF" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
