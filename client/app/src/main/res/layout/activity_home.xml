<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <!-- Ambient Glow / Background decoration -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/glow_circle_cyan"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationX="100dp"
        android:translationY="-100dp"
        android:alpha="0.25"/>

    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:background="@drawable/glow_circle_purple"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-150dp"
        android:translationY="150dp"
        android:alpha="0.2"/>

    <!-- Main Container (centered) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <!-- Branding Header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">
            
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginEnd="16dp"
                android:elevation="8dp"/>
                
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NYXXPAD"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    android:textColor="#FFFFFF"
                    android:textSize="40sp"
                    android:shadowColor="#88000000"
                    android:shadowDx="0.0"
                    android:shadowDy="4.0"
                    android:shadowRadius="12.0" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ULTIMATE VIRTUAL CONTROLLER"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:textColor="#8A2BE2"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Glassmorphism Card for Modes -->
        <LinearLayout
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="32dp"
            android:elevation="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT CONNECTION"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:textColor="#C5C6C7"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnConnectWifi"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Wi-Fi (Local Network)"
                android:drawableStart="@drawable/ic_wifi"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:drawablePadding="16dp"
                android:gravity="center_vertical|start"
                android:background="@drawable/btn_premium_card"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnConnectUsb"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Wired (USB Tethering)"
                android:drawableStart="@drawable/ic_usb"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:drawablePadding="16dp"
                android:gravity="center_vertical|start"
                android:background="@drawable/btn_premium_card"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnConnectBluetooth"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Bluetooth"
                android:drawableStart="@drawable/ic_bluetooth"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:drawablePadding="16dp"
                android:gravity="center_vertical|start"
                android:background="@drawable/btn_premium_card"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
