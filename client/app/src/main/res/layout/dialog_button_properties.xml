<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E2124"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvSheetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PROPERTIES"
        android:fontFamily="monospace"
        android:textColor="#8A2BE2"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvSizeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Size: 1.0x"
        android:textColor="#45A29E"
        android:paddingBottom="8dp" />

    <SeekBar
        android:id="@+id/sbSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="150"
        android:progress="50"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvSpacingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spacing: 1.0x"
        android:textColor="#45A29E"
        android:paddingBottom="8dp" />

    <SeekBar
        android:id="@+id/sbSpacing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="150"
        android:progress="50"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvOpacityLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Opacity: 100%"
        android:textColor="#45A29E"
        android:paddingBottom="8dp" />

    <SeekBar
        android:id="@+id/sbOpacity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="100"
        android:layout_marginBottom="16dp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchVisible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Visible"
        android:textColor="#EDEEF0"
        android:layout_marginBottom="16dp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchTurbo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Turbo (Rapid Fire)"
        android:textColor="#EDEEF0"
        android:layout_marginBottom="16dp" />
        
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchAnalog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Analog Trigger Mode"
        android:textColor="#EDEEF0"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

</LinearLayout>
