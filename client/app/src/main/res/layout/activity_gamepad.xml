<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0C10">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Edit Mode Dim Overlay (blocks accidental game input during editing) -->
        <View
            android:id="@+id/editModeOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#99000000"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="false"
            android:elevation="0dp" />

        <com.nativegamepad.GamepadView
            android:id="@+id/gamepadView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:elevation="1dp" />

        <!-- Floating Hamburger Menu Button (always visible during play) -->
        <ImageButton
            android:id="@+id/btnOpenMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="80dp"
            android:layout_marginStart="16dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#8A2BE2"
            android:elevation="4dp" />

        <!-- Edit Mode Floating Box -->
        <LinearLayout
            android:id="@+id/editModeFloatingBox"
            android:layout_width="340dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:elevation="20dp"
            android:visibility="gone">

            <!-- Header (Drag Handle) -->
            <LinearLayout
                android:id="@+id/editModeHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="#22000000"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvEditModeTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✏ EDIT MODE"
                    android:fontFamily="monospace"
                    android:textColor="#EDEEF0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <!-- Eye / Preview Toggle -->
                <FrameLayout
                    android:id="@+id/btnPreviewToggle"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/glass_card_bg"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:id="@+id/tvEyeIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_eye"
                        android:alpha="0.4" />
                    <!-- Active glow ring shown when preview is ON -->
                    <View
                        android:id="@+id/eyeActiveRing"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/btn_outline"
                        android:alpha="0"
                        android:elevation="1dp" />
                </FrameLayout>
            </LinearLayout>

            <!-- Properties Content (Hidden until an element is selected) -->
            <LinearLayout
                android:id="@+id/layoutPropertiesContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <!-- Element Label -->
                <TextView
                    android:id="@+id/tvSheetTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PROPERTIES"
                    android:fontFamily="monospace"
                    android:textColor="#8A2BE2"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <!-- Row 1: Size and Spacing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Size:" android:textColor="#45A29E" android:textSize="12sp" />
                        <Button android:id="@+id/btnSizeMinus" android:layout_width="32dp" android:layout_height="32dp" android:text="−" android:backgroundTint="#45A29E" android:textColor="#0B0C10" android:textSize="16sp" android:padding="0dp" />
                        <TextView android:id="@+id/tvSizeLabel" android:layout_width="40dp" android:layout_height="wrap_content" android:text="1.0×" android:gravity="center" android:textColor="#EDEEF0" android:textSize="12sp" />
                        <Button android:id="@+id/btnSizePlus" android:layout_width="32dp" android:layout_height="32dp" android:text="+" android:backgroundTint="#45A29E" android:textColor="#0B0C10" android:textSize="16sp" android:padding="0dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowSpacing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Space:" android:textColor="#45A29E" android:textSize="12sp" />
                        <Button android:id="@+id/btnSpacingMinus" android:layout_width="32dp" android:layout_height="32dp" android:text="−" android:backgroundTint="#45A29E" android:textColor="#0B0C10" android:textSize="16sp" android:padding="0dp" />
                        <TextView android:id="@+id/tvSpacingLabel" android:layout_width="40dp" android:layout_height="wrap_content" android:text="1.0×" android:gravity="center" android:textColor="#EDEEF0" android:textSize="12sp" />
                        <Button android:id="@+id/btnSpacingPlus" android:layout_width="32dp" android:layout_height="32dp" android:text="+" android:backgroundTint="#45A29E" android:textColor="#0B0C10" android:textSize="16sp" android:padding="0dp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2: Opacity and Switches -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView android:layout_width="48dp" android:layout_height="wrap_content" android:text="Alpha:" android:textColor="#45A29E" android:textSize="12sp" />
                        <Button android:id="@+id/btnOpacityMinus" android:layout_width="32dp" android:layout_height="32dp" android:text="−" android:backgroundTint="#45A29E" android:textColor="#0B0C10" android:textSize="16sp" android:padding="0dp" />
                        <TextView android:id="@+id/tvOpacityLabel" android:layout_width="40dp" android:layout_height="wrap_content" android:text="100%" android:gravity="center" android:textColor="#EDEEF0" android:textSize="12sp" />
                        <Button android:id="@+id/btnOpacityPlus" android:layout_width="32dp" android:layout_height="32dp" android:text="+" android:backgroundTint="#45A29E" android:textColor="#0B0C10" android:textSize="16sp" android:padding="0dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:gravity="center_vertical">
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchVisible" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Visible" android:textColor="#EDEEF0" android:textSize="12sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchTurbo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Turbo" android:textColor="#EDEEF0" android:textSize="12sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchAnalog" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Analog" android:textColor="#EDEEF0" android:textSize="12sp" android:visibility="gone" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Footer (Cancel/Done) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:padding="12dp"
                android:background="#22000000">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCancelAllEdit"
                    android:layout_width="80dp"
                    android:layout_height="36dp"
                    android:text="CANCEL"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="#FF5C5C"
                    android:background="@drawable/btn_danger_outline"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDoneEdit"
                    android:layout_width="80dp"
                    android:layout_height="36dp"
                    android:text="DONE"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="#0B0C10"
                    android:background="@drawable/btn_success_solid" />
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>


    <ScrollView
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#E60D0F14"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvMenuTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NYXX MENU"
                android:fontFamily="monospace"
                android:textColor="#8A2BE2"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="24dp" />

            <!-- Section 1: CONTROLLER PROFILE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/glass_card_bg"
                android:padding="16dp"
                android:layout_marginBottom="20dp">
                
                <TextView
                    android:id="@+id/tvSectionProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTROLLER PROFILE"
                    android:textColor="#8A2BE2"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvSelectedProfile"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/spinner_bg"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#EDEEF0"
                    android:fontFamily="monospace"
                    android:textSize="14sp"
                    android:drawableEnd="@android:drawable/arrow_down_float"
                    android:drawableTint="#8A2BE2" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnEditLayout"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="✏ EDIT LAYOUT"
                    android:background="@drawable/btn_outline"
                    android:textColor="#EDEEF0"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnResetLayout"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="↺ RESET DEFAULTS"
                    android:background="@drawable/btn_outline"
                    android:textColor="#EDEEF0"
                    android:fontFamily="monospace"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Section 2: SENSORS & HAPTICS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/glass_card_bg"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvSectionSensors"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SENSORS &amp; HAPTICS"
                    android:textColor="#8A2BE2"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="16dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchGyro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gyro Steering"
                    android:textColor="#EDEEF0"
                    android:layout_marginBottom="16dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDanceMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dance Mode (6-DoF)"
                    android:textColor="#EDEEF0"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/layoutGyroMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gyro Mapping"
                        android:textColor="#EDEEF0"
                        android:textSize="12sp"
                        android:paddingBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerGyroMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#EDEEF0" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchRumble"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Haptic Rumble"
                    android:textColor="#EDEEF0" />
            </LinearLayout>

            <!-- Section 3: SYSTEM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/glass_card_bg"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvSectionSystem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYSTEM CONNECTION"
                    android:textColor="#8A2BE2"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="16dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnReconnect"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="⚡ RECONNECT"
                    android:background="@drawable/btn_outline"
                    android:textColor="#EDEEF0"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDisconnect"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="× DISCONNECT &amp; QUIT"
                    android:background="@drawable/btn_danger_outline"
                    android:textColor="#FF5C5C"
                    android:fontFamily="monospace"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.drawerlayout.widget.DrawerLayout>
