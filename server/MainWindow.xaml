<Window x:Class="NativeGamepadServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexus Server" Height="650" Width="700" MinWidth="700" MinHeight="650"
        Background="#0B0C10" Foreground="#EDEEF0"
        WindowStartupLocation="CenterScreen"
        Icon="icon.png"
        StateChanged="Window_StateChanged">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Nyxx Gamepad Server" FontSize="26" FontWeight="Bold" Foreground="#8A2BE2" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock.Effect>
                <DropShadowEffect Color="#8A2BE2" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
            </TextBlock.Effect>
        </TextBlock>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="UDP Port:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" Foreground="#A0A5B0"/>
            <TextBox x:Name="txtPort" Text="5000" Width="80" Height="35" FontSize="16" VerticalContentAlignment="Center" TextAlignment="Center" Margin="0,0,20,0" Background="#1C1F24" Foreground="#EDEEF0" BorderBrush="#8A2BE2"/>
            <Button x:Name="btnToggle" Content="START SERVER" Width="160" Height="40" Background="#8A2BE2" Foreground="White" FontWeight="Bold" FontSize="14" Click="BtnToggle_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A040FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#3D4249" BorderThickness="1" CornerRadius="12" Padding="15" Background="#14161A" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="8" Opacity="0.6"/>
                </Border.Effect>
                <Viewbox>
                    <UniformGrid Columns="2" Rows="2" x:Name="playerGrid">
                        <Border x:Name="slot1" Margin="10" BorderBrush="#3D4249" BorderThickness="2" CornerRadius="10" Background="#0B0C10">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="lblP1" Text="PLAYER 1" FontWeight="Bold" FontSize="20" Foreground="#5B6270" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txtP1" Text="Waiting..." FontSize="14" Foreground="#5B6270" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <StackPanel x:Name="testerP1" Visibility="Collapsed" Margin="0,6,0,0">
                                <Grid Width="140" Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Canvas Grid.Column="0" Width="40" Height="40" HorizontalAlignment="Center">
                                        <Ellipse Width="40" Height="40" Stroke="#3D4249" StrokeThickness="2"/>
                                        <Ellipse x:Name="thumb1L" Width="8" Height="8" Fill="#8A2BE2" Canvas.Left="16" Canvas.Top="16"/>
                                    </Canvas>
                                    <Canvas Grid.Column="1" Width="40" Height="40" HorizontalAlignment="Center">
                                        <Ellipse Width="40" Height="40" Stroke="#3D4249" StrokeThickness="2"/>
                                        <Ellipse x:Name="thumb1R" Width="8" Height="8" Fill="#8A2BE2" Canvas.Left="16" Canvas.Top="16"/>
                                    </Canvas>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                                    <ProgressBar x:Name="prog1L" Width="50" Height="6" Minimum="0" Maximum="255" Value="0" Foreground="#8A2BE2" Margin="0,0,10,0" Background="#1C1F24" BorderThickness="0"/>
                                    <ProgressBar x:Name="prog1R" Width="50" Height="6" Minimum="0" Maximum="255" Value="0" Foreground="#8A2BE2" Background="#1C1F24" BorderThickness="0"/>
                                </StackPanel>
                                <TextBlock x:Name="btn1Txt" Text="--" FontSize="11" Foreground="#00FF00" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border x:Name="slot2" Margin="10" BorderBrush="#3D4249" BorderThickness="2" CornerRadius="10" Background="#0B0C10">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="lblP2" Text="PLAYER 2" FontWeight="Bold" FontSize="20" Foreground="#5B6270" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txtP2" Text="Waiting..." FontSize="14" Foreground="#5B6270" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <StackPanel x:Name="testerP2" Visibility="Collapsed" Margin="0,6,0,0">
                                <Grid Width="140" Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Canvas Grid.Column="0" Width="40" Height="40" HorizontalAlignment="Center">
                                        <Ellipse Width="40" Height="40" Stroke="#3D4249" StrokeThickness="2"/>
                                        <Ellipse x:Name="thumb2L" Width="8" Height="8" Fill="#8A2BE2" Canvas.Left="16" Canvas.Top="16"/>
                                    </Canvas>
                                    <Canvas Grid.Column="1" Width="40" Height="40" HorizontalAlignment="Center">
                                        <Ellipse Width="40" Height="40" Stroke="#3D4249" StrokeThickness="2"/>
                                        <Ellipse x:Name="thumb2R" Width="8" Height="8" Fill="#8A2BE2" Canvas.Left="16" Canvas.Top="16"/>
                                    </Canvas>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                                    <ProgressBar x:Name="prog2L" Width="50" Height="6" Minimum="0" Maximum="255" Value="0" Foreground="#8A2BE2" Margin="0,0,10,0" Background="#1C1F24" BorderThickness="0"/>
                                    <ProgressBar x:Name="prog2R" Width="50" Height="6" Minimum="0" Maximum="255" Value="0" Foreground="#8A2BE2" Background="#1C1F24" BorderThickness="0"/>
                                </StackPanel>
                                <TextBlock x:Name="btn2Txt" Text="--" FontSize="11" Foreground="#00FF00" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border x:Name="slot3" Margin="10" BorderBrush="#3D4249" BorderThickness="2" CornerRadius="10" Background="#0B0C10">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="lblP3" Text="PLAYER 3" FontWeight="Bold" FontSize="20" Foreground="#5B6270" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txtP3" Text="Waiting..." FontSize="14" Foreground="#5B6270" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <StackPanel x:Name="testerP3" Visibility="Collapsed" Margin="0,6,0,0">
                                <Grid Width="140" Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Canvas Grid.Column="0" Width="40" Height="40" HorizontalAlignment="Center">
                                        <Ellipse Width="40" Height="40" Stroke="#3D4249" StrokeThickness="2"/>
                                        <Ellipse x:Name="thumb3L" Width="8" Height="8" Fill="#8A2BE2" Canvas.Left="16" Canvas.Top="16"/>
                                    </Canvas>
                                    <Canvas Grid.Column="1" Width="40" Height="40" HorizontalAlignment="Center">
                                        <Ellipse Width="40" Height="40" Stroke="#3D4249" StrokeThickness="2"/>
                                        <Ellipse x:Name="thumb3R" Width="8" Height="8" Fill="#8A2BE2" Canvas.Left="16" Canvas.Top="16"/>
                                    </Canvas>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                                    <ProgressBar x:Name="prog3L" Width="50" Height="6" Minimum="0" Maximum="255" Value="0" Foreground="#8A2BE2" Margin="0,0,10,0" Background="#1C1F24" BorderThickness="0"/>
                                    <ProgressBar x:Name="prog3R" Width="50" Height="6" Minimum="0" Maximum="255" Value="0" Foreground="#8A2BE2" Background="#1C1F24" BorderThickness="0"/>
                                </StackPanel>
                                <TextBlock x:Name="btn3Txt" Text="--" FontSize="11" Foreground="#00FF00" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border x:Name="slot4" Margin="10" BorderBrush="#3D4249" BorderThickness="2" CornerRadius="10" Background="#0B0C10">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="lblP4" Text="PLAYER 4" FontWeight="Bold" FontSize="20" Foreground="#5B6270" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txtP4" Text="Waiting..." FontSize="14" Foreground="#5B6270" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <StackPanel x:Name="testerP4" Visibility="Collapsed" Margin="0,6,0,0">
                                <Grid Width="140" Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Canvas Grid.Column="0" Width="40" Height="40" HorizontalAlignment="Center">
                                        <Ellipse Width="40" Height="40" Stroke="#3D4249" StrokeThickness="2"/>
                                        <Ellipse x:Name="thumb4L" Width="8" Height="8" Fill="#8A2BE2" Canvas.Left="16" Canvas.Top="16"/>
                                    </Canvas>
                                    <Canvas Grid.Column="1" Width="40" Height="40" HorizontalAlignment="Center">
                                        <Ellipse Width="40" Height="40" Stroke="#3D4249" StrokeThickness="2"/>
                                        <Ellipse x:Name="thumb4R" Width="8" Height="8" Fill="#8A2BE2" Canvas.Left="16" Canvas.Top="16"/>
                                    </Canvas>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                                    <ProgressBar x:Name="prog4L" Width="50" Height="6" Minimum="0" Maximum="255" Value="0" Foreground="#8A2BE2" Margin="0,0,10,0" Background="#1C1F24" BorderThickness="0"/>
                                    <ProgressBar x:Name="prog4R" Width="50" Height="6" Minimum="0" Maximum="255" Value="0" Foreground="#8A2BE2" Background="#1C1F24" BorderThickness="0"/>
                                </StackPanel>
                                <TextBlock x:Name="btn4Txt" Text="--" FontSize="11" Foreground="#00FF00" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    </UniformGrid>
                </Viewbox>
            </Border>

            <Border Grid.Column="1" BorderBrush="#3D4249" BorderThickness="1" CornerRadius="12" Background="#14161A" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="8" Opacity="0.6"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="CONNECT PHONE" FontWeight="Bold" FontSize="16" Foreground="#8A2BE2" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Border Background="White" Padding="10" CornerRadius="8">
                        <Image x:Name="qrImage" Width="140" Height="140" Stretch="Uniform"/>
                    </Border>
                    <TextBlock x:Name="txtIp" Text="IP: 192.168.1.1" FontSize="14" Foreground="#EDEEF0" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" BorderBrush="#3D4249" BorderThickness="1" CornerRadius="12" Background="#14161A">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="8" Opacity="0.6"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#1C1F24" CornerRadius="12,12,0,0" Padding="10,5">
                    <TextBlock Text="Server Log" FontWeight="Bold" Foreground="#8A2BE2"/>
                </Border>
                <ScrollViewer Grid.Row="1" x:Name="logScroll" Margin="10" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtConsole" Foreground="#00FF00" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
